+    / "BATCH_003_SHALLOW_GENERALIZATION_24CASES_V3_AUDITED_20260704"
+)
+CANONICAL_REAL_ROOT = ROOT / "data_corrected_v1_4_terrain_direction"
+V15_FINAL_ROOT = ROOT / "data_yingshan_v15_final_20260710"
