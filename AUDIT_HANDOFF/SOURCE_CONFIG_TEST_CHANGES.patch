+SYNTH_ROOT = ROOT / "data" / "PGDA_SYNTH_DATASET_V1"
+ACCEPTED_ROOT = SYNTH_ROOT / "05_accepted_dataset"
+BATCH3_ROOT = (
+    SYNTH_ROOT
