+def main() -> None:
+    if REPORT.exists():
+        shutil.rmtree(REPORT)
+    REPORT.mkdir(parents=True)
+
+    line_data = {line: load_line(line) for line in LINES}
+    outputs, segment_rows, trace_rows = apply_final_policy(line_data)
+    window_rows = write_dataset(outputs)
