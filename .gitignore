# Python
__pycache__/
*.py[cod]
*.pyc
*.egg-info/
.venv/
venv/

# Per-machine runtime configuration. Copy the committed example and fill this
# file locally; paths to Python, CUDA, and gprMax must never be committed.
environment/project_runtime.local.json
environment/*.machine.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# gprMax simulation outputs (reproducible intermediates)
*.out
*.h5
*.hdf5
*.vti

# Data is deny-by-default. Only governed measured releases, contracts, and V2
# simulation assets are versioned.
data/*
!data/measured/
!data/measured/**
!data/contracts/
!data/contracts/**
!data/simulations/
!data/simulations/v2/
!data/simulations/v2/**
uavgpr_simlab/workspace/

# Workspace (simulation runs)
workspace/

# Logs
logs/
*.log

# Playwright screenshots
.playwright-mcp/

# Claude Code worktrees
.claude/worktrees/
# Keep reproducible control inputs, geometry indices, labels, and audits in Git,
# but leave solver products and execution logs local.
data/simulations/v2/00_controls/**/*.out
data/simulations/v2/00_controls/**/*.log
data/simulations/v2/00_controls/**/*.vti
data/simulations/v2/_staging/
data/simulations/v2/_superseded_*/
data/simulations/v2/01_solver_runs/
# Audited, immutable solver evidence is the only exception to the local-run
# rule. Files enter this directory exclusively through package_gprmax_release.py.
!data/simulations/v2/02_released_solver_evidence/
!data/simulations/v2/02_released_solver_evidence/**
!data/simulations/v2/release_specs/
!data/simulations/v2/release_specs/**
outputs/simulation_v2_controls/
outputs/
