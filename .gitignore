!data/PGDA_SYNTH_DATASET_V2/00_controls/**
# Keep reproducible control inputs, geometry indices, labels, and audits in Git,
# but leave solver products and execution logs local.
data/PGDA_SYNTH_DATASET_V2/00_controls/**/*.out
data/PGDA_SYNTH_DATASET_V2/00_controls/**/*.log
data/PGDA_SYNTH_DATASET_V2/00_controls/**/*.vti
data/PGDA_SYNTH_DATASET_V2/_staging/
data/PGDA_SYNTH_DATASET_V2/_superseded_*/
data/PGDA_SYNTH_DATASET_V2/01_solver_runs/
outputs/simulation_v2_controls/
outputs/
# Native 256 source decks and compact released canonical arrays are shared
# through Git. Raw gprMax .out/.h5/.vti files remain globally ignored above.
!data/PGDA_SYNTH_DATASET_V2/01_native_256_release_pilot/
!data/PGDA_SYNTH_DATASET_V2/01_native_256_release_pilot/**
