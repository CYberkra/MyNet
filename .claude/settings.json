{
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/pgda_safety_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash(train_raw_only|resume_train|train_gprmax_adapter|train_final_from_cv|_keep_training|_retry_train|python.*gprMax|uavgpr_simlab)",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/training_process_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python .claude/hooks/venv_python_guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/py_compile_on_edit.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/py_lint_on_edit.py",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash(train_raw_only|resume_train|train_gprmax_adapter)",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/checkpoint_sanity.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash(eval_full_line)",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/report_on_eval.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
